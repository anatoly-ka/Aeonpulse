<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:Aeonpulse.Helpers"
             x:Class="Aeonpulse.Views.MainMenuPopup"
             BackgroundColor="#80000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <!-- Full-page grid; tap outside the panel dismisses the menu -->
        <Grid HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <!-- Transparent tap-to-dismiss background -->
            <BoxView Color="Transparent"
                     InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseClicked" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Menu panel: top margin and right margin are set in code-behind to align
                 with the bottom of the NavBar and the right edge of the screen. -->
            <Frame x:Name="MenuFrame"
                   BackgroundColor="{DynamicResource CardBackground}"
                   CornerRadius="16"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="{DynamicResource CyberPurple}"
                   HorizontalOptions="End"
                   VerticalOptions="Start">

                <VerticalStackLayout Spacing="0"
                                     MinimumWidthRequest="220">

                    <!-- Title -->
                    <Label Text="AeonPulse"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="{DynamicResource CyberCyan}"
                           Padding="24,20,24,16" />

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             Color="{DynamicResource CyberPurple}"
                             Opacity="0.4"
                             HorizontalOptions="Fill"
                             Margin="0,0,0,8" />

                    <!-- Change Date -->
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="20,12"
                          ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangeDateClicked" />
                        </Grid.GestureRecognizers>
                        <Image Grid.Column="0"
                               Source="profiles.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Center"
                               helpers:ImageTint.Color="{DynamicResource CyberCyan}" />
                        <Label Grid.Column="1"
                               Text="Change Date"
                               FontSize="{StaticResource FontSizeLarge}"
                               TextColor="{DynamicResource TextGray}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Settings -->
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="20,12"
                          ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsClicked" />
                        </Grid.GestureRecognizers>
                        <Image Grid.Column="0"
                               Source="settings.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Center"
                               helpers:ImageTint.Color="{DynamicResource CyberCyan}" />
                        <Label Grid.Column="1"
                               Text="Settings"
                               FontSize="{StaticResource FontSizeLarge}"
                               TextColor="{DynamicResource TextGray}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Exit -->
                    <Grid ColumnDefinitions="Auto,*"
                          Padding="20,12"
                          ColumnSpacing="12">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExitClicked" />
                        </Grid.GestureRecognizers>
                        <Image Grid.Column="0"
                               Source="exit.png"
                               WidthRequest="22"
                               HeightRequest="22"
                               VerticalOptions="Center"
                               helpers:ImageTint.Color="{DynamicResource CyberCyan}" />
                        <Label Grid.Column="1"
                               Text="Exit"
                               FontSize="{StaticResource FontSizeLarge}"
                               TextColor="{DynamicResource TextGray}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1"
                             Color="{DynamicResource CyberPurple}"
                             Opacity="0.4"
                             HorizontalOptions="Fill"
                             Margin="0,8,0,0" />

                    <!-- Footer: Close button -->
                    <VerticalStackLayout Padding="24,12,24,20">
                        <Button Text="Close"
                                Clicked="OnCloseClicked"
                                HorizontalOptions="Center"
                                WidthRequest="160"
                                BackgroundColor="{DynamicResource SpaceDark}"
                                TextColor="{DynamicResource TextGray}"
                                CornerRadius="8"
                                FontSize="{StaticResource FontSizeLarge}"
                                HeightRequest="44"
                                BorderColor="{DynamicResource CyberPurple}"
                                BorderWidth="1" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>
        </Grid>
    </ContentPage.Content>
</ContentPage>