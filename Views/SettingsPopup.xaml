<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Aeonpulse.Views.SettingsPopup"
             BackgroundColor="#80000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <Grid HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <!-- Transparent tap-to-dismiss background -->
            <BoxView Color="Transparent"
                     InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseClicked" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Centered popup panel -->
            <Frame BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="16"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="{StaticResource CyberPurple}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="24,0"
                   MinimumWidthRequest="300">

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Title -->
                    <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,20,24,0">
                        <Label Text="AeonPulse"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource CyberCyan}" />

                        <BoxView HeightRequest="1"
                                 Color="{StaticResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill"
                                 Margin="0,16,0,0" />
                    </VerticalStackLayout>

                    <!-- Content -->
                    <VerticalStackLayout Grid.Row="1" Spacing="16" Padding="24,16">

                        <!-- Settings Section -->
                        <Label Text="Settings"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource CyberPurple}" />

                        <!-- Unit System row -->
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                              VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text="Unit System"
                                   FontSize="14"
                                   TextColor="{StaticResource TextGray}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="Imperial"
                                   FontSize="13"
                                   TextColor="{StaticResource CyberCyan}"
                                   VerticalOptions="Center"
                                   Margin="0,0,4,0" />
                            <Switch x:Name="MetricSwitch"
                                    Grid.Column="2"
                                    OnColor="{StaticResource CyberCyan}"
                                    ThumbColor="{StaticResource TextWhite}"
                                    Toggled="OnMetricSwitchToggled"
                                    VerticalOptions="Center" />
                            <Label Grid.Column="3"
                                   Text="Metric"
                                   FontSize="13"
                                   TextColor="{StaticResource CyberCyan}"
                                   VerticalOptions="Center"
                                   Margin="4,0,0,0" />
                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill" />

                        <!-- About Section -->
                        <Label Text="About"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource CyberPurple}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="AeonPulse v0.1.0"
                                   FontSize="13"
                                   TextColor="{StaticResource TextGray}" />
                            <Label Text="Track life metrics and milestones in a visually striking cyberpunk aesthetic."
                                   FontSize="13"
                                   TextColor="{StaticResource TextGray}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="Created with passion for time, data, and cosmic wonder."
                                   FontSize="13"
                                   TextColor="{StaticResource TextGray}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Footer -->
                    <VerticalStackLayout Grid.Row="2" Padding="24,0,24,20" Spacing="0">
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill"
                                 Margin="0,0,0,16" />
                        <Button Text="Close"
                                Clicked="OnCloseClicked"
                                HorizontalOptions="Center"
                                WidthRequest="160"
                                BackgroundColor="{StaticResource SpaceDark}"
                                TextColor="{StaticResource TextGray}"
                                CornerRadius="8"
                                FontSize="15"
                                HeightRequest="44"
                                BorderColor="{StaticResource CyberPurple}"
                                BorderWidth="1" />
                    </VerticalStackLayout>

                </Grid>
            </Frame>
        </Grid>
    </ContentPage.Content>
</ContentPage>