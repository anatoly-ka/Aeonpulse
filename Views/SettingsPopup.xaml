<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Aeonpulse.Views.SettingsPopup"
             BackgroundColor="#80000000"
             Shell.NavBarIsVisible="False">

    <ContentPage.Content>
        <Grid HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <!-- Transparent tap-to-dismiss background -->
            <BoxView Color="Transparent"
                     InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCloseClicked" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Centered popup panel -->
            <Frame BackgroundColor="{DynamicResource CardBackground}"
                   CornerRadius="16"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="{DynamicResource CyberPurple}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="24,0"
                   MinimumWidthRequest="300">

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Title -->
                    <VerticalStackLayout Grid.Row="0" Spacing="0" Padding="24,20,24,0">
                        <Label Text="AeonPulse"
                               FontSize="{StaticResource FontSizeTitle}"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{DynamicResource CyberCyan}" />

                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill"
                                 Margin="0,16,0,0" />
                    </VerticalStackLayout>

                    <!-- Content -->
                    <VerticalStackLayout Grid.Row="1" Spacing="16" Padding="24,16">

                        <!-- Settings Section -->
                        <Label Text="Settings"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource CyberPurple}" />

                        <!--
                            Single shared grid for ALL parameter rows.
                            Column 0 (Auto) = parameter labels  — sized to the widest label.
                            Column 1 (*)    = radio buttons     — all share the same left edge.
                            ColumnSpacing pushes radios away from labels consistently.
                        -->
                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                              ColumnSpacing="16"
                              RowSpacing="8">

                            <!-- Row 0: Unit System label (spans both radio rows via RowSpan) -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Grid.RowSpan="2"
                                   Text="Unit System"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   TextColor="{DynamicResource TextGray}"
                                   VerticalOptions="Center" />

                            <!-- Row 0: Metric radio -->
                            <HorizontalStackLayout Grid.Row="0" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="Center">
                                <RadioButton x:Name="MetricRadio"
                                             Value="Metric"
                                             GroupName="UnitSystem"
                                             CheckedChanged="OnUnitSystemChanged">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                                <Ellipse Grid.Column="0"
                                                         WidthRequest="16"
                                                         HeightRequest="16"
                                                         Stroke="{DynamicResource CyberCyan}"
                                                         StrokeThickness="2"
                                                         Fill="Transparent" />
                                                <Ellipse x:Name="InnerDot"
                                                         Grid.Column="0"
                                                         WidthRequest="8"
                                                         HeightRequest="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Fill="{DynamicResource CyberCyan}"
                                                         IsVisible="{TemplateBinding IsChecked}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalOptions="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                                <Label Text="Metric"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{DynamicResource CyberCyan}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Row 1: Imperial radio -->
                            <HorizontalStackLayout Grid.Row="1" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="Center">
                                <RadioButton x:Name="ImperialRadio"
                                             Value="Imperial"
                                             GroupName="UnitSystem"
                                             CheckedChanged="OnUnitSystemChanged">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                                <Ellipse Grid.Column="0"
                                                         WidthRequest="16"
                                                         HeightRequest="16"
                                                         Stroke="{DynamicResource CyberCyan}"
                                                         StrokeThickness="2"
                                                         Fill="Transparent" />
                                                <Ellipse x:Name="InnerDot"
                                                         Grid.Column="0"
                                                         WidthRequest="8"
                                                         HeightRequest="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Fill="{DynamicResource CyberCyan}"
                                                         IsVisible="{TemplateBinding IsChecked}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalOptions="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                                <Label Text="Imperial"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{DynamicResource CyberCyan}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Row 2: spacer between parameter groups -->
                            <BoxView Grid.Row="2" Grid.ColumnSpan="2"
                                     HeightRequest="4"
                                     Color="Transparent" />

                            <!-- Row 3: Color Scheme label (spans all radio rows via RowSpan) -->
                            <Label Grid.Row="3" Grid.Column="0"
                                   Grid.RowSpan="3"
                                   Text="Color Scheme"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   TextColor="{DynamicResource TextGray}"
                                   VerticalOptions="Center" />

                            <!-- Row 3: Default Dark radio -->
                            <HorizontalStackLayout Grid.Row="3" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="Center">
                                <RadioButton x:Name="DefaultDarkRadio"
                                             Value="DefaultDark"
                                             GroupName="ColorScheme"
                                             CheckedChanged="OnColorSchemeChanged">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                                <Ellipse Grid.Column="0"
                                                         WidthRequest="16"
                                                         HeightRequest="16"
                                                         Stroke="{DynamicResource CyberCyan}"
                                                         StrokeThickness="2"
                                                         Fill="Transparent" />
                                                <Ellipse x:Name="InnerDot"
                                                         Grid.Column="0"
                                                         WidthRequest="8"
                                                         HeightRequest="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Fill="{DynamicResource CyberCyan}"
                                                         IsVisible="{TemplateBinding IsChecked}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalOptions="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                                <Label Text="Default Dark"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{DynamicResource CyberCyan}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Row 4: High Contrast Dark radio -->
                            <HorizontalStackLayout Grid.Row="4" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="Center">
                                <RadioButton x:Name="HighContrastDarkRadio"
                                             Value="HighContrastDark"
                                             GroupName="ColorScheme"
                                             CheckedChanged="OnColorSchemeChanged">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                                <Ellipse Grid.Column="0"
                                                         WidthRequest="16"
                                                         HeightRequest="16"
                                                         Stroke="{DynamicResource CyberCyan}"
                                                         StrokeThickness="2"
                                                         Fill="Transparent" />
                                                <Ellipse x:Name="InnerDot"
                                                         Grid.Column="0"
                                                         WidthRequest="8"
                                                         HeightRequest="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Fill="{DynamicResource CyberCyan}"
                                                         IsVisible="{TemplateBinding IsChecked}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalOptions="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                                <Label Text="High Contrast Dark"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{DynamicResource CyberCyan}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <!-- Row 5: High Contrast Light radio -->
                            <HorizontalStackLayout Grid.Row="5" Grid.Column="1"
                                                   Spacing="6"
                                                   HorizontalOptions="Start"
                                                   VerticalOptions="Center">
                                <RadioButton x:Name="HighContrastLightRadio"
                                             Value="HighContrastLight"
                                             GroupName="ColorScheme"
                                             CheckedChanged="OnColorSchemeChanged">
                                    <RadioButton.ControlTemplate>
                                        <ControlTemplate>
                                            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                                                <Ellipse Grid.Column="0"
                                                         WidthRequest="16"
                                                         HeightRequest="16"
                                                         Stroke="{DynamicResource CyberCyan}"
                                                         StrokeThickness="2"
                                                         Fill="Transparent" />
                                                <Ellipse x:Name="InnerDot"
                                                         Grid.Column="0"
                                                         WidthRequest="8"
                                                         HeightRequest="8"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center"
                                                         Fill="{DynamicResource CyberCyan}"
                                                         IsVisible="{TemplateBinding IsChecked}" />
                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalOptions="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </RadioButton.ControlTemplate>
                                </RadioButton>
                                <Label Text="High Contrast Light"
                                       FontSize="{StaticResource FontSizeMedium}"
                                       TextColor="{DynamicResource CyberCyan}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                        </Grid>

                        <!-- Divider -->
                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill" />

                        <!-- About Section -->
                        <Label Text="About"
                               FontSize="{StaticResource FontSizeMedium}"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource CyberPurple}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="AeonPulse v0.1.0"
                                   FontSize="{StaticResource FontSizeMedium}"
                                   TextColor="{DynamicResource TextGray}" />
                            <Label Text="Track life metrics and milestones in a visually striking cyberpunk aesthetic."
                                   FontSize="{StaticResource FontSizeMedium}"
                                   TextColor="{DynamicResource TextGray}"
                                   LineBreakMode="WordWrap" />
                            <Label Text="Created with passion for time, data, and cosmic wonder."
                                   FontSize="{StaticResource FontSizeMedium}"
                                   TextColor="{DynamicResource TextGray}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!-- Footer -->
                    <VerticalStackLayout Grid.Row="2" Padding="24,0,24,20" Spacing="0">
                        <BoxView HeightRequest="1"
                                 Color="{DynamicResource CyberPurple}"
                                 Opacity="0.4"
                                 HorizontalOptions="Fill"
                                 Margin="0,0,0,16" />
                        <Button Text="Close"
                                Clicked="OnCloseClicked"
                                HorizontalOptions="Center"
                                WidthRequest="160"
                                BackgroundColor="{DynamicResource SpaceDark}"
                                TextColor="{DynamicResource TextGray}"
                                CornerRadius="8"
                                FontSize="{StaticResource FontSizeLarge}"
                                HeightRequest="44"
                                BorderColor="{DynamicResource CyberPurple}"
                                BorderWidth="1" />
                    </VerticalStackLayout>

                </Grid>
            </Frame>
        </Grid>
    </ContentPage.Content>
</ContentPage>